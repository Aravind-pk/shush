---
import { Icon } from "astro-icon/components";

interface Props {
  size?: number;
  withText?: boolean;
  textSize?: number;
}

const { size = 30, withText = true, textSize = 19 } = Astro.props;
---

<div class="flex items-center gap-2.5">
  <div
    class="flex items-center justify-center"
    style={`width:${size}px;height:${size}px;border-radius:${Math.round(
      size * 0.27,
    )}px;background:radial-gradient(circle at 35% 30%,#f5c518,#f5841f 45%,#a64ba6 80%);box-shadow:0 0 16px rgba(245,132,31,0.4)`}
  >
    <Icon name="lucide:asterisk" style={`color:#0a0a0b`} width={size * 0.5} height={size * 0.5} />
  </div>
  {
    withText && (
      <span
        class="font-bold tracking-[-0.02em] text-fg"
        style={`font-size:${textSize}px`}
      >
        shush
      </span>
    )
  }
</div>
