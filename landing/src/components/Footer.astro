---
import Logo from "./Logo.astro";
import { GITHUB_URL, DOCS_URL, SECURITY_URL, LICENSE_URL } from "../config";

const links = [
  { label: "Docs", href: DOCS_URL },
  { label: "GitHub", href: GITHUB_URL },
  { label: "Security", href: SECURITY_URL },
  { label: "License", href: LICENSE_URL },
];
---

<footer
  class="container-px mt-[70px] flex flex-wrap items-center justify-between gap-4 border-t border-hair py-10"
>
  <div class="flex items-center gap-2.5">
    <Logo size={26} textSize={15} />
    <span class="ml-2 text-[13px] text-faint">© 2026 Shush · Apache-2.0</span>
  </div>
  <div class="flex gap-[22px]">
    {
      links.map((l) => (
        <a href={l.href} class="text-[13.5px] text-[#7d7d84] transition-colors hover:text-white">
          {l.label}
        </a>
      ))
    }
  </div>
</footer>
