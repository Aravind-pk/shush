
# Postgres
POSTGRES_USER=shush
POSTGRES_PASSWORD=shush
POSTGRES_DB=shush

# Backend
DATABASE_URL=postgres://shush:shush@localhost:5432/shush?sslmode=disable
MASTER_KEK=change-me-32-bytes-exactly-padded
# Clerk secret key — verifies session tokens. Find it in the Clerk dashboard
# (API keys) or in frontend/.env.local. Starts with sk_test_ / sk_live_.
CLERK_SECRET_KEY=sk_test_xxx
