---
import { Icon } from "astro-icon/components";
import Terminal from "./Terminal.astro";

const onboardBad = [
  { icon: "lucide:file-x", text: "Hunt down the right .env file" },
  { icon: "lucide:message-square-off", text: "Paste secrets into Slack / DMs" },
  { icon: "lucide:refresh-cw-off", text: "Re-share keys after every rotation" },
  { icon: "lucide:book-x", text: "Maintain a stale setup doc" },
];
const term = [
  { color: "#6a6a70", text: "$ shush login" },
  { color: "#3ddc84", text: "✓ welcome, dev@acme.dev" },
  { color: "#6a6a70", text: "$ shush run --env dev -- pnpm dev" },
  { color: "#9a9aa0", text: "  → access: payments-api · dev (Viewer)" },
  { color: "#dcdce0", text: "▸ running. zero setup, zero .env." },
];
---

<section class="container-px my-[50px]">
  <div class="card grid overflow-hidden lg:grid-cols-[1.05fr_1fr]">
    <div class="border-b border-hair p-7 sm:p-10 lg:border-r lg:border-b-0 lg:p-12">
      <div class="mb-3.5 text-[13px] font-semibold tracking-[0.04em] text-brand-purple">
        DEV ONBOARDING
      </div>
      <h3 class="text-[24px] font-bold leading-[1.14] tracking-[-0.02em] text-heading sm:text-[28px] lg:text-[30px]">
        A new dev ships on day one. No <span class="font-mono text-[0.83em]">.env</span> handoff.
      </h3>
      <p class="mt-4 text-[15.5px] leading-[1.6] text-dim">
        No more hunting for the right keys, copying a teammate's <span
          class="font-mono text-[#cfcfd5]">.env</span
        >, or pasting secrets into Slack. They log in, they're granted access to
        the project, and Shush does the rest.
      </p>
      <div class="mt-[26px] flex flex-col gap-[11px]">
        {
          onboardBad.map((o) => (
            <div class="flex items-center gap-[11px] text-[14.5px] text-muted">
              <Icon name={o.icon} width={18} height={18} style="color:#5f5f66" />
              <span class="line-through" style="text-decoration-color:#5a5a60">
                {o.text}
              </span>
            </div>
          ))
        }
      </div>
    </div>
    <div class="flex items-center p-7 sm:p-10 lg:p-12">
      <Terminal label="day-one.sh" lines={term} ellipsis class="w-full" />
    </div>
  </div>
</section>
